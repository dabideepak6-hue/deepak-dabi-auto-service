```javascript id="xv3b8n"
rules_version = '2';

service cloud.firestore {

  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isDriver() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "driver";
    }

    function isCustomer() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "customer";
    }

    // ======================
    // USERS
    // ======================

    match /users/{userId} {

      allow read: if signedIn() && request.auth.uid == userId;

      allow create: if signedIn() && request.auth.uid == userId;

      allow update: if signedIn() && request.auth.uid == userId;

      allow delete: if isAdmin();

    }

    // ======================
    // RIDES
    // ======================

    match /rides/{rideId} {

      // Customer, Driver (assigned), Admin
      allow read: if isAdmin() ||

        (signedIn() &&
          (
            resource.data.customerId == request.auth.uid ||
            resource.data.driverId == request.auth.uid
          )
        );

      // Customer creates own ride
      allow create: if isCustomer() &&
        request.resource.data.customerId == request.auth.uid;

      // Driver or Customer update their own ride
      allow update: if isAdmin() ||

        (isDriver() &&
          resource.data.driverId == request.auth.uid) ||

        (isCustomer() &&
          resource.data.customerId == request.auth.uid);

      allow delete: if isAdmin();

    }

    // ======================
    // DRIVERS
    // ======================

    match /drivers/{driverId} {

      allow read: if signedIn();

      allow create: if isDriver() &&
        request.auth.uid == driverId;

      allow update: if isDriver() &&
        request.auth.uid == driverId;

      allow delete: if isAdmin();

    }

    // ======================
    // PAYMENTS
    // ======================

    match /payments/{paymentId} {

      allow read: if signedIn();

      allow create: if signedIn();

      allow update: if isAdmin();

      allow delete: if isAdmin();

    }

    // ======================
    // RATINGS
    // ======================

    match /ratings/{ratingId} {

      allow read: if signedIn();

      allow create: if isCustomer();

      allow update: if false;

      allow delete: if isAdmin();

    }

  }

}
```
